# ============================================================================
# Test Environment — ANTHROPIC secrets for integration test projects
# ============================================================================
# Copy this file to .env.test and fill in your values.
# These are injected into the test project's per-project agent config at
# creation time (see tests/integration.test.ts).

# Required for integration tests
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: use a proxy or alternative endpoint
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: override the default model for test sessions
# ANTHROPIC_MODEL=claude-sonnet-4-6
