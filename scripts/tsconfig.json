{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"types": ["../apps/api/node_modules/bun-types"],
		"paths": {
			"drizzle-orm/*": ["../project-template/node_modules/drizzle-orm/*"]
		},
		"noEmit": true
	},
	"include": ["./**/*", "../project-template/src/agent/tools/definitions.ts"],
	// Override the root tsconfig's `exclude` (inherited via `extends`), which
	// contains "scripts" and would otherwise strip out every file matched by
	// `include` above — leaving tsc checking zero files and exiting 0.
	"exclude": []
}
