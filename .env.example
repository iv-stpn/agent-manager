# ============================================================================
# Orchestrator API & Web
# ============================================================================
# api (project manager) and web (single UI) run on the orchestrator.
# Per-project Anthropic config is NOT set here — it is captured per
# project at creation (UI / CLI) and stored in each project's .env.
PORT=3100
ORCHESTRATOR_PORT=3100
ORCHESTRATOR_WEB_URL=http://localhost:3101

# Bearer token gating the orchestrator API (/api/*). Optional: when unset, the
# API is open (loopback-trust mode) and warns at startup. When set, the web
# dashboard must be built with a matching VITE_ORCHESTRATOR_API_TOKEN (below)
# and project containers receive it automatically.
ORCHESTRATOR_API_TOKEN=

# When "true", the API stops all running project containers on SIGINT/SIGTERM.
# Default off: with `bun --watch` in dev, every file save restarts the process,
# and stopping containers on each reload would kill running agents. Enable only
# for production deployments where a clean shutdown should tear everything down.
ORCHESTRATOR_STOP_CONTAINERS_ON_SHUTDOWN=false

# ── Web dashboard (apps/web, Vite) ──────────────────────────────────────────
# Base URL of the orchestrator API the dashboard talks to.
VITE_API_URL=http://localhost:3100
# Must match ORCHESTRATOR_API_TOKEN above when auth is enabled. Baked into the
# client bundle at build time (loopback-trust convenience gate, not a secret).
VITE_ORCHESTRATOR_API_TOKEN=

# ============================================================================
# Discord (global bot)
# ============================================================================
# A single Discord bot manages all projects. Set these to enable it.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ============================================================================
# Workspace & Agent Settings
# ============================================================================
# Where the agent works
WORKSPACE_PATH=/workspace
# Max concurrent agent sessions (0 = unlimited)
MAX_CONCURRENT_SESSIONS=5

# ============================================================================
# Advanced Settings
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info