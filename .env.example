# ============================================================================
# Orchestrator API & Web
# ============================================================================
# orchestrator-api (project manager) and orchestrator-web (single UI) run on the orchestrator.
# Per-project Anthropic config is NOT set here — it is captured per
# project at creation (UI / CLI) and stored in each project's .env.
PORT=3100
ORCHESTRATOR_PORT=3100
ORCHESTRATOR_WEB_URL=http://localhost:3101
NEXT_PUBLIC_API_URL=http://localhost:3100

# ============================================================================
# Discord (global bot)
# ============================================================================
# A single Discord bot manages all projects. Set these to enable it.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ============================================================================
# Workspace & Agent Settings
# ============================================================================
# Where the agent works
WORKSPACE_PATH=/workspace
# Max concurrent agent sessions (0 = unlimited)
MAX_CONCURRENT_SESSIONS=5

# ============================================================================
# Advanced Settings
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info