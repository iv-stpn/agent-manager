# ============================================================================
# Host API & Web
# ============================================================================
# host-api (project manager) and host-web (single UI) run on the host.
# Per-project Anthropic + Discord config is NOT set here — it is captured per
# project at creation (UI / CLI) and stored in each project's config.json + .env.
PORT=3100
HOST_PORT=3100
HOST_WEB_URL=http://localhost:3101
NEXT_PUBLIC_API_URL=http://localhost:3100

# ============================================================================
# Workspace & Agent Settings
# ============================================================================
# Where the agent works (will create .agent/ structure inside)
WORKSPACE_PATH=/workspace
# Max concurrent agent sessions (0 = unlimited)
MAX_CONCURRENT_SESSIONS=5

# ============================================================================
# Advanced Settings
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info