{
	"name": "agent-manager",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"project-template"
	],
	"scripts": {
		"dev": "scripts/dev.sh",
		"gen:db-md": "bun run scripts/gen-db-md.ts",
		"dev:api": "bun run --elide-lines=0 --filter @agent-manager/host-api dev",
		"dev:web": "bun run --elide-lines=0 --filter @agent-manager/host-web dev",
		"build": "bun run --filter '*' build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"projects": "bun run apps/cli/projects.ts",
		"stop-all": "bun run scripts/stop-all-projects.ts",
		"test": "bun test",
		"typecheck": "bun run --cwd apps/host-api build:types && bun run --cwd project-template build:types && (cd apps/host-api && tsc --noEmit) && (cd apps/host-web && tsc --noEmit) && tsc -p packages/projects/tsconfig.json --noEmit && (cd project-template && tsc --noEmit)",
		"test:setup": "bun run tests/setup.test.ts",
		"test:e2e": "bun run tests/e2e.test.ts",
		"test:integration": "scripts/run-integration.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"concurrently": "^9.1.0"
	}
}
