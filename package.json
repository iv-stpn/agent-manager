{
	"name": "agent-manager",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"project-template"
	],
	"scripts": {
		"clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
		"dev": "scripts/dev.sh",
		"db:reset:seed": "bun run scripts/reset-seed-db.ts",
		"gen:db-md": "bun run scripts/gen-db-md.ts",
		"gen:tools-md": "bun run scripts/gen-tools-md.ts",
		"gen:docs": "bun run gen:db-md && bun run gen:tools-md",
		"prepare": "husky",
		"dev:api": "bun run --elide-lines=0 --filter @agent-manager/host-api dev",
		"dev:web": "bun run --elide-lines=0 --filter @agent-manager/host-web dev",
		"build": "bun run --filter '*' build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"projects": "bun run apps/cli/projects.ts",
		"stop-all": "bun run scripts/stop-all-projects.ts",
		"typecheck": "bun run --cwd apps/host-api build:types && bun run --cwd project-template build:types && (cd apps/host-api && tsc --noEmit) && (cd apps/host-web && tsc --noEmit) && (cd project-template && tsc --noEmit) && tsc -p packages/db/tsconfig.json --noEmit && tsc -p packages/projects/tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
		"knip": "knip"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"husky": "^9.1.7",
		"knip": "^6.23.0",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"@radix-ui/react-checkbox": "^1.3.5",
		"concurrently": "^9.1.0"
	}
}
