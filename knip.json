{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"workspaces": {
		".": {
			"entry": ["scripts/**/*.ts"],
			"project": ["scripts/**/*.ts"],
			"ignoreDependencies": ["concurrently"],
			"ignoreBinaries": ["scripts/dev.sh"]
		},
		"apps/api": {
			"project": ["src/**/*.ts"],
			"ignore": ["src/lancedb/**"]
		},
		"apps/web": {
			"project": ["src/**/*.{ts,tsx}"],
			"ignore": ["src/components/ui/**"]
		},
		"apps/cli": {
			"project": ["*.ts"]
		},
		"packages/db": {
			"project": ["src/**/*.ts"]
		},
		"packages/projects": {
			"project": ["src/**/*.ts"],
			"ignoreBinaries": ["up", "down", "logs", "ps", "build"]
		},
		"packages/utils": {
			"project": ["src/**/*.ts"]
		},
		"project-template": {
			"project": ["src/**/*.ts"]
		}
	}
}
